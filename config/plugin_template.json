{
  "name": "sample-plugin",
  "version": "1.0.0",
  "description": "Sample plugin for AI agent sustainable evolution",
  "module": "src.plugins.sample_plugin",
  "lifecycles": {
    "load": "load_plugin",
    "execute": "execute_task",
    "shutdown": "cleanup_resources"
  },
  "permissions": [
    "read_memory",
    "call_tool:searxng"
  ],
  "dependencies": [
    "base_agent"
  ],
  "security": {
    "network_whitelist": [
      "10.0.0.0/8"
    ],
    "file_read_paths": [
      "/app/data/"
    ]
  }
}