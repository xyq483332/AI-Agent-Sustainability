# AI Agent Sustainability - Environment Variables
# Copy to .env and fill in real values before deployment.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_use_strong_password

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_use_strong_password

# ── OpenTelemetry (optional, override defaults) ──────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=plugin-system
